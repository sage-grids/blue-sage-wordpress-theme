{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "blue-sage/hero",
	"version": "1.0.0",
	"title": "BS — Hero",
	"category": "blue-sage",
	"description": "High-end hero section in three layouts: Centered Statement (dark), Split (light), or Editorial (oversized type).",
	"keywords": [ "hero", "banner", "header", "landing" ],
	"textdomain": "blue-sage",
	"attributes": {
		"layout": {
			"type": "string",
			"default": "centered",
			"enum": [ "centered", "split", "editorial" ]
		},
		"eyebrow": {
			"type": "string",
			"default": ""
		},
		"heading": {
			"type": "string",
			"default": ""
		},
		"subheading": {
			"type": "string",
			"default": ""
		},
		"description": {
			"type": "string",
			"default": ""
		},
		"primaryCta": {
			"type": "object",
			"default": { "label": "Get Started Free", "url": "#", "newTab": false }
		},
		"secondaryCta": {
			"type": "object",
			"default": { "label": "See the Demo", "url": "#", "newTab": false }
		},
		"mediaId": {
			"type": "integer",
			"default": 0
		},
		"mediaUrl": {
			"type": "string",
			"default": ""
		},
		"mediaAlt": {
			"type": "string",
			"default": ""
		},
		"gradientHeading": {
			"type": "boolean",
			"default": false
		}
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"spacing": {
			"margin": [ "top", "bottom" ],
			"padding": false
		},
		"color": false
	},
	"editorScript": "blue-sage-blocks-editor",
	"style":       "file:./style.css",
	"editorStyle": "file:./editor.css",
	"render":      "file:./render.php"
}
